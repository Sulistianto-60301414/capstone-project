PORT=3000

# MQTT
MQTT_URL=mqtt://192.168.137.89:1883
MQTT_TOPICS=hospital/mri/001/#
MQTT_USERNAME=
MQTT_PASSWORD=

# Dashboard
MAX_POINTS=120
TICK_MS=1000
ALERT_MAX=200

# IPFIX (optional)
