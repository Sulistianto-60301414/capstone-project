IPFIX_POLL_MS=5000
IPFIX_WINDOW_MS=300000
IPFIX_COMMAND=
IPFIX_DEVICE_IP=192.168.137.141
IPFIX_BROKER_IP=192.168.137.89

# Firebase Realtime Database (optional)
FIREBASE_SERVICE_ACCOUNT=/absolute/path/to/serviceAccount.json
FIREBASE_DB_URL=https://capstone-project-adaee-default-rtdb.firebaseio.com
